# ============================================================
# Alyto Backend V2.0 — .env.example
# Copiar a .env y completar con valores reales.
# ⚠ NUNCA commitear el archivo .env — contiene secretos.
# ============================================================

# ─── Servidor ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
APP_URL=http://localhost:3000

# ─── MongoDB ─────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/alyto-v2
# Producción: mongodb+srv://user:pass@cluster.mongodb.net/alyto-v2

# ─── JWT / Auth ───────────────────────────────────────────────
JWT_SECRET=cambiar_por_secreto_largo_y_aleatorio_en_produccion
JWT_EXPIRES_IN=7d

# ─── Stellar Network ─────────────────────────────────────────
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_PASSPHRASE=Test SDF Network ; September 2015
# Producción:
# STELLAR_NETWORK=public
# STELLAR_HORIZON_URL=https://horizon.stellar.org
# STELLAR_PASSPHRASE=Public Global Stellar Network ; September 2015

# Claves públicas por entidad (safe para loguear)
STELLAR_LLC_PUBLIC_KEY=
STELLAR_SPA_PUBLIC_KEY=
STELLAR_SRL_PUBLIC_KEY=

# Claves privadas — SOLO en entorno seguro, jamás en código fuente
# En producción usar AWS Secrets Manager o equivalente
STELLAR_LLC_SECRET_KEY=
STELLAR_SPA_SECRET_KEY=
STELLAR_SRL_SECRET_KEY=
STELLAR_CHANNEL_SECRET=     # channelAccount para Fee Bump transactions

# ─── Stripe (AV Finance LLC) ──────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ─── Fintoc (AV Finance SpA — Chile) ─────────────────────────
FINTOC_SECRET_KEY=sk_test_...
FINTOC_WEBHOOK_SECRET=pk_test_...
FINTOC_REDIRECT_URL=http://localhost:5173/payin/success

# ─── OwlPay / Harbor (AV Finance LLC) ────────────────────────
OWLPAY_API_KEY=
OWLPAY_BASE_URL=https://harbor-api.owlpay.com
OWLPAY_WEBHOOK_SECRET=

# ─── Vita Wallet — Stage (desarrollo / QA) ───────────────────
# Base URL: NO incluir /api/businesses — el servicio lo agrega internamente
VITA_API_URL=https://api.stage.vitawallet.io
VITA_LOGIN=                     # xLogin del negocio en Vita
VITA_TRANS_KEY=                 # xTransKey del negocio en Vita
VITA_SECRET=                    # Secret Key para firma HMAC-SHA256
VITA_BUSINESS_WALLET_UUID=      # UUID de la master wallet AV Finance en Vita
# URL pública donde Vita envía los IPN — apuntar al endpoint V2
VITA_NOTIFY_URL=https://tu-dominio.com/api/v1/ipn/vita

# ─── Vita Wallet — Producción (dejar vacías hasta go-live) ───
VITA_API_URL_PROD=https://api.vitawallet.io
VITA_LOGIN_PROD=
VITA_TRANS_KEY_PROD=
VITA_SECRET_PROD=
VITA_BUSINESS_WALLET_UUID_PROD=
VITA_NOTIFY_URL_PROD=https://tu-dominio.com/api/v1/ipn/vita

# ─── SendGrid ─────────────────────────────────────────────────
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxx
SENDGRID_FROM_EMAIL=pagos@alyto.app
# Email del admin que recibe notificaciones de payout manual (Bolivia, fallos)
ADMIN_EMAIL=admin@alyto.app
SENDGRID_ADMIN_EMAIL=admin@alyto.app
SUPPORT_EMAIL=soporte@alyto.app
# IDs de Dynamic Templates (crear en SendGrid → Email API → Dynamic Templates)
SENDGRID_TEMPLATE_INITIATED=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_COMPLETED=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_FAILED=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
SENDGRID_TEMPLATE_ADMIN_BOLIVIA=d-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Soporte
SUPPORT_WHATSAPP=+56988321490
APP_ADMIN_URL=http://localhost:3000

# ─── AV Finance SRL — Compliance Bolivia ─────────────────────
AV_FINANCE_NIT=                 # NIT de AV Finance SRL ante el SIN boliviano
AV_FINANCE_ADDRESS=             # Dirección legal registrada
AV_FINANCE_LEGAL_FOOTER=        # Texto legal para el Comprobante Oficial PDF
AV_FINANCE_LOGO_PATH=           # Ruta absoluta al logo para el header del PDF

# ─── Firebase (notificaciones push — Fase 19) ────────────────
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# ─── Sentry (monitoreo de errores) ───────────────────────────
# Obtener en sentry.io → Create Project → Node.js → DSN
# Formato: https://xxxxxx@xxxxxxx.ingest.sentry.io/xxxxxxx
# Dejar vacío para deshabilitar (desarrollo local sin cuenta)
SENTRY_DSN=

# ─── CORS ────────────────────────────────────────────────────
# Producción: especificar el dominio del frontend
# CORS_ORIGIN=https://app.alyto.io
CORS_ORIGIN=*
